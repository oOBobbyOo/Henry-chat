{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 200,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "insertFinalNewline": true,
  "endOfLine": "lf",
  "singleAttributePerLine": true,
  "ignorePatterns": ["dist/**", "build/**", ".next/**", "node_modules/**", "**/*.d.ts"]
}
